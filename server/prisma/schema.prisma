generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

/// Mirrors a row in Supabase's auth.users, kept in sync by the
/// handle_new_user trigger (see the supabase_auth_sync migration).
/// Credentials and sessions live in Supabase Auth, not here.
model User {
  id            String    @id @db.Uuid
  email         String    @unique
  name          String?
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  conversations Conversation[]
  workspaces     WorkspaceUser[]
  teams          Team[]
  automations    Automation[]
  documents      Document[]
  prompts        Prompt[]
  connections    Connection[]
  usageLogs      UsageLog[]
  invoices       Invoice[]
  oauthStates    OAuthState[]

  @@map("profiles")
}

model Conversation {
  id        String    @id @default(uuid())
  userId    String    @db.Uuid
  title     String
  provider  String?
  model     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   Message[]
  usageLogs  UsageLog[]

  @@index([userId, updatedAt])
}

model Message {
  id           String   @id @default(uuid())
  conversationId String
  role         String
  content      String
  provider     String?
  model        String?
  tokensIn     Int?
  tokensOut    Int?
  cost         Float?
  createdAt    DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Specialist {
  id          String   @id @default(uuid())
  name        String   @unique
  role        String
  description String
  model       String
  capabilities Json
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teamMembers TeamMember[]
}

model Workspace {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  plan      String    @default("FREE")
  aiCredits Float     @default(0) // AI credits wallet (topped up via Paystack)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users       WorkspaceUser[]
  creditTransactions CreditTransaction[]
  teams       Team[]
  automations Automation[]
  documents   Document[]
  connections Connection[]
  prompts     Prompt[]
  oauthStates OAuthState[]
}

model WorkspaceUser {
  id         String   @id @default(uuid())
  userId     String   @db.Uuid
  workspaceId String
  role       String   @default("MEMBER")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Model {
  id                  String   @id @default(uuid())
  name                String
  provider            String
  description         String
  contextWindow       Int
  inputPricePerMillion Float
  outputPricePerMillion Float
  capabilities        Json
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Team {
  id          String    @id @default(uuid())
  name        String
  description String?
  workspaceId String
  createdBy   String    @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User          @relation(fields: [createdBy], references: [id])
  members   TeamMember[]

  @@index([workspaceId])
}

model TeamMember {
  id          String   @id @default(uuid())
  teamId      String
  specialistId String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  specialist Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)

  @@unique([teamId, specialistId])
}

model Automation {
  id          String    @id @default(uuid())
  name        String
  description String?
  triggerType String
  triggerConfig Json
  steps       Json
  active      Boolean   @default(true)
  createdBy   String    @db.Uuid
  workspaceId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator   User      @relation(fields: [createdBy], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Document {
  id          String    @id @default(uuid())
  title       String
  filename    String
  mimeType    String
  size        Int
  url         String
  workspaceId String
  uploadedBy  String    @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  uploader   User      @relation(fields: [uploadedBy], references: [id])
  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chunks     DocumentChunk[]

  @@index([workspaceId])
}

model DocumentChunk {
  id         String   @id @default(uuid())
  documentId String
  content    String
  embedding  Unsupported("vector(1536)")?
  metadata   Json
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model Prompt {
  id          String    @id @default(uuid())
  title       String
  content     String
  tags        Json
  workspaceId String
  createdBy   String    @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator   User      @relation(fields: [createdBy], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Connection {
  id           String   @id @default(uuid())
  provider     String
  name         String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  status       String   @default("active")
  workspaceId  String
  userId       String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, provider])
  @@index([workspaceId])
}

model OAuthState {
  id          String    @id @default(uuid())
  state       String    @unique
  provider    String
  userId      String    @db.Uuid
  workspaceId String
  used        Boolean   @default(false)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([state])
  @@index([userId])
  @@index([workspaceId])
}

model UsageLog {
  id             String    @id @default(uuid())
  userId         String    @db.Uuid
  conversationId String?
  provider       String?
  model          String?
  tokensIn       Int
  tokensOut      Int
  cost           Float
  createdAt      DateTime  @default(now())

  user         User          @relation(fields: [userId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])

  @@index([userId, createdAt])
}

model BillingPlan {
  id          String    @id @default(uuid())
  name        String    @unique
  description String
  price       Float
  interval    String
  features    Json
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  invoices Invoice[]
}

enum InvoiceStatus {
  paid
  pending
  failed
}

model Invoice {
  id             String         @id @default(uuid())
  userId         String         @db.Uuid
  planId         String
  amount         Float
  status         InvoiceStatus  @default(pending)
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user User      @relation(fields: [userId], references: [id])
  plan BillingPlan @relation(fields: [planId], references: [id])

  @@index([userId])
}

// ============================================================================
// AI COO — business domain (a Workspace is the business). Scalar workspaceId
// (no back-relation) so existing models are untouched.
// ============================================================================
model Product {
  id           String        @id @default(uuid())
  workspaceId  String
  name         String
  sku          String?
  barcode      String?
  category     String?
  price        Float         @default(0)
  cost         Float         @default(0)
  stock        Int           @default(0)
  reorderPoint Int           @default(0)
  unit         String             @default("unit")
  createdAt    DateTime           @default(now())
  items        SalesInvoiceItem[]

  @@index([workspaceId])
}

model Customer {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  phone       String?
  createdAt   DateTime       @default(now())
  invoices    SalesInvoice[]
  payments    Payment[]

  @@index([workspaceId])
}

model SalesInvoice {
  id          String             @id @default(uuid())
  workspaceId String
  customerId  String
  number      String
  amount      Float              @default(0)
  status      String             @default("unpaid") // unpaid | partial | paid
  issuedAt    DateTime           @default(now())
  dueAt       DateTime
  createdAt   DateTime           @default(now())
  // POS fields
  channel     String             @default("manual") // manual | pos
  discount    Float              @default(0)
  tax         Float              @default(0)
  tendered    Float?             // cash given by customer (for change)
  change      Float?             // change returned
  cashierId   String?
  shiftId     String?
  clientId    String?            @unique // idempotency key for offline sync
  customer    Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items       SalesInvoiceItem[]
  payments    Payment[]

  @@index([workspaceId])
  @@index([shiftId])
}

// Per-store POS configuration: tax, hardware toggles, receipt text.
model StoreSettings {
  id             String   @id @default(uuid())
  workspaceId    String   @unique
  taxEnabled     Boolean  @default(false)
  taxRates       Json?    // [{ name: "VAT", rate: 15 }, ...]
  taxInclusive   Boolean  @default(false) // prices already include tax
  barcodeEnabled Boolean  @default(false)
  printerEnabled Boolean  @default(false)
  cashDrawer     Boolean  @default(false)
  receiptHeader  String?
  receiptFooter  String?  @default("Thank you! Come again.")
  updatedAt      DateTime @updatedAt
}

// A person who operates the till, signs in with a short PIN.
model Cashier {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  pinHash     String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  shifts      Shift[]

  @@index([workspaceId])
}

// A till session: opened with a cash float, closed with a counted total.
model Shift {
  id           String    @id @default(uuid())
  workspaceId  String
  cashierId    String
  openingFloat Float     @default(0)
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  countedCash  Float?    // what the cashier counted at close
  status       String    @default("open") // open | closed
  cashier      Cashier   @relation(fields: [cashierId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model SalesInvoiceItem {
  id        String       @id @default(uuid())
  invoiceId String
  productId String
  qty       Int          @default(1)
  unitPrice Float        @default(0)
  invoice   SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([productId])
}

model Payment {
  id          String        @id @default(uuid())
  workspaceId String
  invoiceId   String?
  customerId  String?
  amount      Float         @default(0)
  method      String        @default("momo") // momo | cash | bank
  receivedAt  DateTime      @default(now())
  invoice     SalesInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  customer    Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model Expense {
  id          String   @id @default(uuid())
  workspaceId String
  category    String
  amount      Float    @default(0)
  note        String?
  spentAt     DateTime @default(now())

  @@index([workspaceId])
}

model CooAction {
  id          String   @id @default(uuid())
  workspaceId String
  kind        String // reminder | restock | payroll | tax
  title       String
  detail      String?
  status      String   @default("pending") // pending | approved | declined | done
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([workspaceId])
}

// Every change to a shop's AI-credit wallet: top-ups (Paystack), AI usage,
// and any bonuses/adjustments. `amount` is signed (+ topup, − usage).
model CreditTransaction {
  id           String   @id @default(uuid())
  workspaceId  String
  type         String   // topup | usage | bonus | adjustment
  amount       Float    // signed credits
  balanceAfter Float
  reference    String?  // Paystack reference for top-ups
  note         String?
  createdAt    DateTime @default(now())

  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// A supplier bill / purchase when restocking — paid, on credit, or part-paid.
// The paid portion also creates an Expense so cash-on-hand stays right; the
// unpaid remainder is what the shop owes its suppliers.
model Purchase {
  id          String   @id @default(uuid())
  workspaceId String
  supplier    String
  amount      Float    @default(0)
  amountPaid  Float    @default(0)
  status      String   @default("paid") // paid | partial | credit
  note        String?
  photo       String?  // data URL of the invoice photo (downscaled)
  createdAt   DateTime @default(now())

  @@index([workspaceId])
}

// A browser/phone that has opted in to push notifications (the daily briefing).
// One row per device (endpoint). Removed automatically when the push service
// reports the subscription is gone (410/404).
model PushSubscription {
  id          String   @id @default(uuid())
  workspaceId String
  endpoint    String   @unique
  p256dh      String
  auth        String
  createdAt   DateTime @default(now())

  @@index([workspaceId])
}
