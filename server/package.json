    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.10.0",
    "bullmq": "^5.12.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5",
    "openai": "^6.7.0",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "rate-limiter-flexible": "^5.0.5",
    "stripe": "^16.0.0",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.13.2",
    "prisma": "^6.10.0",
    "tsx": "^4.19.0",
    "typescript": "~6.0.2",
    "vitest": "^2.0.0"
  }
