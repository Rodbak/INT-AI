{
  "buildCommand": "npm run build --workspace=app",
  "outputDirectory": "app/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": {
    "fallback": [
      { "source": "/(.*)", "destination": "/index.html" }
    ]
  }
}
